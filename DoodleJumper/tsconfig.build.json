{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "emitDeclarationOnly": false,
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/dev.ts",
    "node_modules",
    "dist",
    "tests",
    "scripts"
  ]
}